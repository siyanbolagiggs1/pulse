# Server
PORT=5000
NODE_ENV=development   # set to "production" in prod (enables Gin release mode)

# MongoDB
MONGODB_URI=mongodb://admin:secret@mongodb:27017/pulse?authSource=admin
DB_NAME=pulse

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@pulse.app

# App
CLIENT_URL=http://localhost:3000
UPLOAD_DIR=./uploads
PLATFORM_COMMISSION_RATE=0.20

# MongoDB root credentials (used by docker-compose only, not the API)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=secret

# Production-only
# CLIENT_URL=https://pulse.app         (set to your real frontend URL for CORS)
# REDIS_PASSWORD=change-me-in-prod     (used by docker-compose.prod.yml)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY   (used by docker-compose.prod.yml build arg)
