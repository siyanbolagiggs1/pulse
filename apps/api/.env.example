# Server
PORT=5000
NODE_ENV=development   # set to "production" in prod (enables Gin release mode)

# MongoDB
MONGODB_URI=mongodb://admin:secret@mongodb:27017/pulse?authSource=admin
DB_NAME=pulse

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Paystack
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_CURRENCY=NGN   # or USD, GHS, ZAR, KES, etc.

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@pulse.app

# App
CLIENT_URL=http://localhost:3000
UPLOAD_DIR=./uploads
PLATFORM_COMMISSION_RATE=0.20

# Support chat (automatic welcome message feature)
# Email of an existing admin-role user; the chat system looks this user up at
# runtime and uses their account to auto-message every new signup (and, via
# the admin backfill endpoint, every existing user) a one-time welcome message.
# Leave blank to disable the feature entirely (no-op, never fails registration).
SUPPORT_ADMIN_EMAIL=

# AI support assistant (auto-replies in support conversations)
# Groq is tried first (fast, generous free tier); Gemini is the fallback for
# replies and the only embeddings provider (used to match a new question
# against previously-answered ones). Leave both blank to disable entirely —
# messages to support just wait for a human, same as before this feature.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# MongoDB root credentials (used by docker-compose only, not the API)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=secret

# Production-only
# CLIENT_URL=https://your-app.vercel.app   (set to your real frontend URL for CORS)
# REDIS_PASSWORD=change-me-in-prod          (used by docker-compose.prod.yml)
